{% extends 'base.html.twig' %}

{% block title %}Responsable — Pointages du jour{% endblock %}

{% block body %}
<div class="screen">
    <header class="top-bar">
        <span class="top-bar__title">Pointages du jour</span>
        <a href="{{ path('app_index') }}" class="outline-button">← Retour</a>
    </header>

    <main class="page-content page-content--narrow">
        <p class="list-heading">
            {{ "now"|date("d/m/Y") }} — {{ clockings|length }} pointage{{ clockings|length > 1 ? 's' : '' }}
        </p>

        {% if clockings is empty %}
            <div class="no-clocking-message">Aucun pointage aujourd'hui.</div>
        {% else %}
            <div class="clocking-log">
                {% for clocking in clockings %}
                    <div class="clocking-entry">
                        <span class="clocking-entry__employee-name">
                            {{ clocking.employee.firstName }} {{ clocking.employee.lastName }}
                        </span>
                        <span class="clocking-entry__timestamp">
                            {{ clocking.createdAt|date('H:i:s') }}
                        </span>
                        <span class="clocking-type-badge {{ clocking.type == 'in' ? 'clocking-type-badge--arrival' : 'clocking-type-badge--departure' }}">
                            {{ clocking.type == 'in' ? 'Arrivée' : 'Départ' }}
                        </span>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </main>
</div>
{% endblock %}
